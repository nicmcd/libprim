prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
datarootdir = ${prefix}/share
datadir=${prefix}/share

Name: libprim
Description: Native data types for C++ renamed for convience
URL: https://github.com/nicmcd/libprim
Version: 0.1.0
Requires:
Libs: -L${libdir} -lprim
Cflags: -I${includedir}
